server {
    listen 80;
    server_name {{ site_name }};

    client_max_body_size 64m;
    keepalive_timeout 65;

    root /var/www/wordpress;
    index index.php;

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php{{ php_version }}-fpm.sock;
    }
}
